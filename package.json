{
  "name": "yuknow",
  "private": true,
  "version": "1.1.1",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "push": "git add . && git commit -m \"chore: auto update\" && git push origin main",
    "release:patch": "npm version patch && git push --follow-tags origin main",
    "release:minor": "npm version minor && git push --follow-tags origin main",
    "release:major": "npm version major && git push --follow-tags origin main"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
